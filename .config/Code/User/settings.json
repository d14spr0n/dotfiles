{
    // ==== EDITOR SECTION ====
    "editor.lineHeight": 24,
    "editor.fontFamily": "Cascadia Code",
    "editor.fontSize": 17,
    "editor.mouseWheelZoom": false,
    "editor.renderControlCharacters": true,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.showSlider": "always",
    "editor.fontLigatures": false,
    "editor.showFoldingControls": "always",
    "editor.wordWrap": "on",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleReferences": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",
    "editor.suggestSelection": "first",
    "editor.multiCursorModifier": "alt",
    "editor.lineNumbers": "on",
    "editor.codeLens": false,
    "editor.scrollBeyondLastLine": true,
    "editor.inlayHints.fontFamily": "Cascadia Code",
    "editor.inlayHints.fontSize": 13,
    // the following options are used to disable automatic intellisense
    // "editor.quickSuggestions": {
    //     "comments": "off",
    //     "strings": "off",
    //     "other": "off"
    // },
    // "editor.suggestOnTriggerCharacters": false,
    // "editor.wordBasedSuggestions": "off",
    "editor.parameterHints.enabled": false,
    // change comments color for default theme
    // disable underline for variables and methods
    "editor.semanticTokenColorCustomizations": {
        "enabled": true
    },
    // ==== WORKBENCH SECTION ====
    "workbench.editor.showTabs": "multiple",
    "workbench.startupEditor": "none",
    "workbench.statusBar.visible": true,
    // ==== TERMINAL SECTION ====
    "terminal.integrated.fontSize": 17,
    "terminal.integrated.lineHeight": 1.1,
    "terminal.integrated.letterSpacing": 0,
    "terminal.integrated.fontFamily": "Cascadia Code",
    // ==== DEBUG SECTION ====
    "debug.inlineValues": "on",
    "debug.console.fontFamily": "Cascadia Code",
    "debug.console.fontSize": 17,
    // ==== TELEMETRY SECTION ====
    "telemetry.telemetryLevel": "off",
    // ==== VIM SECTION ====
    // "vim.disableExtension": false,
    // "vim.incsearch": true,
    // "vim.hlsearch": true,
    // "vim.ignorecase": true,
    // "vim.smartcase": true,
    // "vim.useSystemClipboard": true,
    // "vim.leader": "<space>",
    // "vim.normalModeKeyBindingsNonRecursive": [
    //     {
    //         "before": [
    //             "<C-[>"
    //         ],
    //         "commands": [
    //             ":noh"
    //         ]
    //     }
    // ],
    // ==== MISC SECTION ====
    "http.proxyStrictSSL": false,
    "go.useLanguageServer": true,
    "extensions.ignoreRecommendations": true,
    // "explorer.openEditors.visible": 0,
    "window.titleBarStyle": "custom",
    "window.commandCenter": true,
    "notebook.output.textLineLimit": 50,
    "debug.allowBreakpointsEverywhere": true,
    "editor.renderWhitespace": "none",
    "editor.formatOnSave": true,
    "editor.hover.enabled": "off",
    "editor.cursorBlinking": "solid",
    "workbench.sideBar.location": "right",
}